# Dependencies
node_modules/
npm-debug.log

# Database files — the live database should not be in version control
*.db
*.sqlite
*.sqlite3

# macOS system files
.DS_Store
.AppleDouble

# Environment files — may contain API keys or machine-specific paths
.env
.env.local
.env.production
.env*.local

# SQLite WAL mode sidecar files
*.db-shm
*.db-wal

# Build outputs
dist/
build/
.cache/

# Drizzle config compiled output (drizzle-kit compiles drizzle.config.ts at runtime)
drizzle.config.js
drizzle.config.js.map
drizzle.config.d.ts
drizzle.config.d.ts.map

# Logs
*.log
logs/
claude-code/

# Depwire auto-generated cache
.depwire/

# Playwright / E2E test artefacts
e2e.db
playwright-report/
test-results/
