{
  "name": "travel-tracker",
  "version": "0.1.0",
  "description": "Personal travel tracker — local Mac app with interactive world map",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch src/backend/server.ts",
    "start": "tsx src/backend/server.ts",
    "build": "vite build",
    "type:check": "tsc -p tsconfig.frontend.json --noEmit",
    "type:check:backend": "tsc -p tsconfig.backend.json --noEmit",
    "postinstall": "patch-package",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/backend/db/seed.ts",
    "db:studio": "drizzle-kit studio",
    "test:backend": "vitest run --config vitest.config.backend.ts",
    "test:backend:watch": "vitest --config vitest.config.backend.ts",
    "test:frontend": "vitest run --config vitest.config.frontend.ts",
    "test:frontend:watch": "vitest --config vitest.config.frontend.ts",
    "test:contract": "vitest run --config vitest.config.contract.ts",
    "test:contract:watch": "vitest --config vitest.config.contract.ts",
    "test:contract:coverage": "vitest run --config vitest.config.contract.ts --coverage",
    "test:e2e": "SQLITE_PATH=file:./e2e.db npm run db:migrate && playwright test",
    "test:e2e:clean": "rm -f ./e2e.db"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.3",
    "@libsql/client": "^0.14.0",
    "@tanstack/react-query": "^5.90.21",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.38.3",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "maplibre-gl": "^5.19.0",
    "pg": "^8.11.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-map-gl": "^8.1.0",
    "react-router-dom": "^6.30.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/helmet": "^0.0.48",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "0.31.9",
    "jsdom": "^28.1.0",
    "patch-package": "^8.0.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
